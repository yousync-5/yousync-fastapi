# 🔧 환경 변수 설정 예시 파일
# 이 파일을 복사해서 .env 파일을 만드세요: cp .env.example .env

# 데이터베이스 설정
DB_NAME=movie_script_db
DB_USER=admin
DB_PASSWORD=securepassword123
DB_HOST=db
DB_PORT=5432

# 데이터베이스 연결 URL (위 설정들을 조합한 전체 URL)
DATABASE_URL=postgresql://admin:securepassword123@db:5432/movie_script_db

# API 서버 설정
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# pgAdmin 설정 (PostgreSQL 관리 도구)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# 참고사항:
# - 프로덕션 환경에서는 더 강력한 비밀번호를 사용하세요
# - SECRET_KEY는 실제 배포시 랜덤한 값으로 변경하세요
# - 이 파일은 Git에 올라가므로 실제 비밀번호를 넣지 마세요
